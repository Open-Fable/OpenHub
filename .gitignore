apps/

# Build output
dist/
out/
*.dmg
*.zip
*.app

# Electron
release/

# Environment (secrets NEVER on disk — use Keychain)
.env
.env.local
.env.production

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Test coverage
coverage/

# TypeScript build cache
*.tsbuildinfo

# Runtime config templates (user-specific copies, not the shared templates)
config/openhub-settings.json
config/openhub-projects.json
config/openhub-memory.json
config/selected-models.json
config/opencode.local.json

# Build artifacts
build/

# Scratch / temp / recovery scripts
scratch/
salvage*.cjs
recover_*.cjs
check_keys.js
test_syntax.py
SECURITY_AND_BUGS_REPORT.md

# Graphify output (regenerated on demand, user-specific)
graphify-out/

# Brand design files (working documents, user-specific)
fichier-de-la-marque/

# User-specific memory / personal data (never share between users)
/AGENT-MEMORY.md
/MEMORY-SYSTEM.md
/openhub-projects.html

