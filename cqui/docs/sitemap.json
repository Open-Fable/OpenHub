{
  "site_name": "Solenia",
  "version": "1.0.0",
  "structure": {
    "public": {
      "home": {
        "path": "/",
        "description": "Page d'accueil avec mise en avant des collections et de la philosophie de marque."
      },
      "shop": {
        "path": "/boutique",
        "sub_pages": {
          "all_products": "/boutique/tous",
          "shoes": "/boutique/chaussures",
          "insoles": "/boutique/semelles",
          "accessories": "/boutique/accessoires"
        }
      },
      "product_detail": {
        "path": "/produit/:slug",
        "description": "Fiche produit détaillée avec sélecteur de variantes et caractéristiques techniques."
      },
      "about": {
        "path": "/a-propos",
        "description": "Histoire de Solenia, nos engagements et notre expertise biomécanique."
      },
      "contact": {
        "path": "/contact",
        "description": "Formulaire de contact et support client."
      },
      "cart": {
        "path": "/panier",
        "description": "Récapitulatif des articles sélectionnés."
      },
      "checkout": {
        "path": "/paiement",
        "steps": ["Identification", "Livraison", "Paiement Sécurisé", "Confirmation"]
      }
    },
    "customer_account": {
      "dashboard": "/mon-compte",
      "orders": "/mon-compte/commandes",
      "profile": "/mon-compte/profil",
      "addresses": "/mon-compte/adresses"
    },
    "admin": {
      "dashboard": "/admin",
      "inventory": "/admin/produits",
      "orders_management": "/admin/commandes",
      "customers_list": "/admin/clients",
      "analytics": "/admin/statistiques"
    },
    "legal": {
      "terms": "/mentions-legales",
      "privacy": "/politique-confidentialite",
      "shipping": "/livraison-et-retours",
      "cgv": "/conditions-generales-de-vente"
    }
  }
}
