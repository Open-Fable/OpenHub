# OpenHub Environment Variables
# IMPORTANT: Real secrets go in macOS Keychain, NOT in .env files.
# This file documents the env vars that the process-manager injects at spawn time.

# Proxy token (generated per session by Electron main — never set manually)
# OPENHUB_TOKEN=<auto-generated>

# Gemini-via-OAuth credentials (the public Gemini CLI "installed app" client).
# These are NOT committed in source — the Gemini OAuth route is disabled unless both
# are provided here. Get the public values from the upstream gemini-cli project.
# GEMINI_CLIENT_ID=<gemini-cli public client id>
# GEMINI_CLIENT_SECRET=<gemini-cli public client secret>

# App ports (defaults — only override if you have conflicts)
# OPENWORK_APP_PORT=5173
# OPENCODE_PORT=4096
# OPENHUB_PROXY_PORT=9999

# Node version manager (uncomment your tool)
# OPENHUB_NODE_MANAGER=fnm
# OPENHUB_NODE_MANAGER=volta
